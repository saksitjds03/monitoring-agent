# Environment Variables for Agent Service Monitoring
# Copy this file to .env and fill in your actual values

# RabbitMQ Management UI
RABBITMQ_URL=http://nest_rabbitmq:15672

# Redis (no HTTP endpoint by default, leave empty)
REDIS_URL=

# PostgreSQL (no HTTP endpoint by default, leave empty)
POSTGRES_URL=

# Your custom services
STATUS_MANAGER_URL=http://status-manager-service:80
DASHBOARD_URL=http://dashboard-report-service:80
ALERT_URL=http://alert-notification-service:80
HEALTH_URL=http://health-monitoring-service:80

# Secrets (Extracted from docker-compose.yml)
DB_HOST=postgres-db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
DB_DATABASE=monitoring
POSTGRES_PASSWORD=your_postgres_password
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
AGENT_SECRET=your_agent_secret_key

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
